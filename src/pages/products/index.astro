---
// Importing necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
import { SITE } from '@data/constants';
import Why from '@/components/sections/landing/Why.astro';

export const prerender = false;

interface ProductItem {
  id: number | string;
  name?: string;
  description?: string;
  category?: string;
  image_url?: string;
  image?: string;
  imageUrl?: string;
}

const apiBase = import.meta.env.PUBLIC_API || 'https://gk-api-t0fo.onrender.com';
let products: ProductItem[] = [];

try {
  const response = await fetch(`${apiBase}/templates`, {
    cache: 'no-store',
  });

  if (!response.ok) {
    throw new Error(`Templates request failed: ${response.status}`);
  }

  const data = await response.json();
  products = Array.isArray(data) ? data : [];
} catch (error) {
  console.error('Error loading products:', error);
}

// Define variables for page content
const title: string = 'Products';
const subTitle: string =
  'Explore the durability and precision of G K Enterprise tools, designed for both professionals and enthusiasts. Each of our products is crafted with precision and built to last, ensuring you have the right tool for every job.';

const pageTitle: string = `Products | ${SITE.title}`;
const metaDescription =
  'Explore the durability and precision of G K Enterprise tools, designed for both professionals and enthusiasts.';
const ogTitle = 'Hardware Tools | G K Enterprise';

const getProductImage = (product: ProductItem) =>
  product.image_url || product.image || product.imageUrl || '';
const getProductSlug = (product: ProductItem) =>
  encodeURIComponent(String(product.id));
const getProductDescription = (product: ProductItem) =>
  product.description
    ? `${product.description.slice(0, 100)}${product.description.length > 100 ? '...' : ''}`
    : 'View full specifications and application details.';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://G K Enterprise.uk/products',
    url: 'https://G K Enterprise.uk/products',
    name: 'Hardware Tools | G K Enterprise',
    description:
      'Explore the durability and precision of G K Enterprise tools, designed for both professionals and enthusiasts.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://G K Enterprise.uk',
      name: 'G K Enterprise',
      description:
        'G K Enterprise offers top-tier hardware tools and expert construction services to meet all your project needs.',
    },
    inLanguage: 'en-US',
  }}
>
  <div
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <div class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12">
      <div class="flex items-center gap-12">
        <h1
          class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
        >
          {title}
        </h1>
        {
          subTitle && (
            <p class="hidden max-w-(--breakpoint-sm) text-pretty text-neutral-600 md:block dark:text-neutral-400">
              {subTitle}
            </p>
          )
        }
      </div>
      <PrimaryCTA title="Customer Stories" url="#testimonials" noArrow={true} />
    </div>

    <section class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        products.length > 0 ? (
          products.map((productItem) => (
            <article class="group overflow-hidden rounded-3xl border border-neutral-200/70 bg-white shadow-lg transition duration-500 hover:-translate-y-2 hover:shadow-2xl dark:border-white/10 dark:bg-neutral-900/70">
              <a href={`/products/${getProductSlug(productItem)}`} class="block">
                <div class="relative overflow-hidden bg-neutral-100 p-4 dark:bg-white/10">
                  <img
                    src={getProductImage(productItem)}
                    alt={productItem.name || 'Product image'}
                    class="h-56 w-full rounded-2xl object-contain transition duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="space-y-3 p-6">
                  <p class="text-xs font-semibold uppercase tracking-[0.25em] text-orange-600">
                    {productItem.category || 'Product'}
                  </p>
                  <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">
                    {productItem.name || 'Product'}
                  </h2>
                  <p class="text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                    {getProductDescription(productItem)}
                  </p>
                  <div class="inline-flex items-center gap-2 text-sm font-semibold text-neutral-900 transition group-hover:translate-x-1 dark:text-white">
                    View Details
                    <span aria-hidden="true">→</span>
                  </div>
                </div>
              </a>
            </article>
          ))
        ) : (
          <div class="rounded-3xl border border-dashed border-neutral-300 p-8 text-center text-sm text-neutral-500 md:col-span-2 xl:col-span-3 dark:border-neutral-700 dark:text-neutral-400">
            No products available right now.
          </div>
        )
      }
    </section>
  </div>

  <Why />
</MainLayout>
