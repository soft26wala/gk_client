---
import Layout from '../../layouts/MainLayout.astro';

export const prerender = false;

const { id } = Astro.params;
const apiBase = import.meta.env.PUBLIC_API || 'https://gk-api-t0fo.onrender.com';

let product: Record<string, any> | null = null;

try {
  const response = await fetch(`${apiBase}/templates/${id}`, {
    cache: 'no-store',
  });

  if (!response.ok) {
    throw new Error(`API Error: ${response.status}`);
  }

  product = await response.json();
} catch (error) {
  console.error(error);
}

const pageTitle = product?.name
  ? `${product.name} | G K Enterprise`
  : 'Product not found | G K Enterprise';

const rawDescription = typeof product?.description === 'string' ? product.description : '';
const imageUrl = product?.image_url || product?.image || product?.imageUrl || '';

const formatText = (value: string) =>
  value
    .replace(/\r/g, '')
    .replace(/\s+\n/g, '\n')
    .replace(/\n{3,}/g, '\n\n')
    .trim();

const extractSection = (text: string, startMarker: string, endMarkers: string[]) => {
  const startIndex = text.indexOf(startMarker);
  if (startIndex === -1) return '';

  const afterMarker = text.slice(startIndex + startMarker.length);
  const nextIndex = endMarkers.reduce((closest, marker) => {
    const index = afterMarker.indexOf(marker);
    if (index >= 0 && (closest === -1 || index < closest)) {
      return index;
    }
    return closest;
  }, -1);

  const sectionText = nextIndex === -1 ? afterMarker : afterMarker.slice(0, nextIndex);
  return formatText(sectionText);
};

const introText = formatText(
  rawDescription
    .split('###')[0]
    .replace(/^Product\s*Features\s*:??\s*$/i, '')
    .replace(/^Product\s*Benefits\s*:??\s*$/i, '')
    .replace(/^Cost\s*Efficiency\s*:??\s*$/i, '')
    .replace(/^Applications\s*:??\s*$/i, '')
    .replace(/^Benefits\s*:??\s*$/i, '')
    .replace(/^Available\s*Sizes\s*:??\s*$/i, '')
    .replace(/^Available\s*Pitch\s*Sizes\s*:??\s*$/i, '')
);

const sections = [
  ...(introText
    ? [{ title: 'Description', content: introText }]
    : []),
  ...[
    {
      title: 'Product Features',
      marker: '###PRODUCT_FEATURES###',
      endMarkers: ['###APPLICATIONS###', '###PRODUCT_BENEFITS###', '###COST_EFFICIENCY###', '###BENEFITS_COST###', '###AVAILABLE_SIZES###', '###AVAILABLE_PITCH_SIZES###', '###BENEFITS###'],
    },
    {
      title: 'Applications',
      marker: '###APPLICATIONS###',
      endMarkers: ['###PRODUCT_BENEFITS###', '###COST_EFFICIENCY###', '###BENEFITS_COST###', '###AVAILABLE_SIZES###', '###AVAILABLE_PITCH_SIZES###', '###BENEFITS###'],
    },
    {
      title: 'Product Benefits',
      marker: '###PRODUCT_BENEFITS###',
      endMarkers: ['###COST_EFFICIENCY###', '###BENEFITS_COST###', '###AVAILABLE_SIZES###', '###AVAILABLE_PITCH_SIZES###', '###BENEFITS###'],
    },
    {
      title: 'Cost Efficiency',
      marker: '###COST_EFFICIENCY###',
      endMarkers: ['###BENEFITS_COST###', '###AVAILABLE_SIZES###', '###AVAILABLE_PITCH_SIZES###', '###BENEFITS###'],
    },
    {
      title: 'Benefits of GK Enterprise MBT Couplers Cost',
      marker: '###BENEFITS_COST###',
      endMarkers: ['###AVAILABLE_SIZES###', '###AVAILABLE_PITCH_SIZES###', '###BENEFITS###'],
    },
    {
      title: 'Available Sizes',
      marker: '###AVAILABLE_SIZES###',
      endMarkers: ['###AVAILABLE_PITCH_SIZES###', '###BENEFITS###'],
    },
    {
      title: 'Available Pitch Sizes',
      marker: '###AVAILABLE_PITCH_SIZES###',
      endMarkers: ['###BENEFITS###'],
    },
    {
      title: 'Benefits',
      marker: '###BENEFITS###',
      endMarkers: [],
    },
  ]
    .map((item) => ({
      title: item.title,
      content: extractSection(rawDescription, item.marker, item.endMarkers),
    }))
    .filter((item) => item.content)
];
---

<Layout title={pageTitle}>
  <main class="min-h-screen px-4 pb-12 pt-24 dark:bg-neutral-800 dark:text-white">
    <div class="mx-auto max-w-7xl">
      {product ? (
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
          <div>
            {imageUrl && (
              <img
                src={imageUrl}
                alt={product.name || 'Product image'}
                class="w-full rounded-3xl object-contain"
              />
            )}
          </div>

          <div class="space-y-8">
            <div class="space-y-3">
              <p class="text-sm font-semibold uppercase tracking-[0.25em] text-orange-600">
                {product.category || 'Product'}
              </p>
              <h1 class="text-4xl font-black sm:text-5xl">{product.name}</h1>
            </div>

            {sections.length > 0 ? (
              <div class="space-y-6">
                {sections.map((section) => (
                  <div class="rounded-3xl border border-neutral-300/80 bg-white/80 p-8 shadow-sm dark:border-neutral-700 dark:bg-neutral-900/70">
                    <h2 class="mb-4 text-2xl font-bold">{section.title}</h2>
                    <p class="whitespace-pre-line text-base leading-8 text-neutral-700 dark:text-neutral-300">
                      {section.content}
                    </p>
                  </div>
                ))}
              </div>
            ) : (
              <div class="rounded-3xl border border-dashed border-neutral-300 p-10 text-center text-lg text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
                No details available.
              </div>
            )}

            <a
              href="/products"
              class="inline-flex items-center gap-2 rounded-full border border-neutral-300 px-5 py-3 text-sm font-semibold text-neutral-800 transition hover:-translate-y-0.5 hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-100 dark:hover:bg-neutral-800"
            >
              ← Back to products
            </a>
          </div>
        </div>
      ) : (
        <div class="rounded-3xl border border-dashed border-neutral-300 p-10 text-center text-lg text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
          Product not found.
        </div>
      )}
    </div>
  </main>
</Layout>