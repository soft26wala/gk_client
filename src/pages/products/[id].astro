---
import Layout from '../../layouts/MainLayout.astro';

export const prerender = false;

const { id } = Astro.params;
const apiBase = import.meta.env.PUBLIC_API || 'https://gk-api-t0fo.onrender.com';

let product: Record<string, any> | null = null;

try {
  const response = await fetch(`${apiBase}/templates/${id}`, {
    cache: 'no-store',
  });

  if (!response.ok) {
    throw new Error(`API Error: ${response.status}`);
  }

  product = await response.json();
} catch (error) {
  console.error(error);
}

const pageTitle = product?.name
  ? `${product.name} | G K Enterprise`
  : 'Product not found | G K Enterprise';

const rawDescription = typeof product?.description === 'string' ? product.description : '';
const imageUrl = product?.image_url || product?.image || product?.imageUrl || '';

const normalizeText = (value: string) =>
  value.replace(/\r/g, '').replace(/\u00a0/g, ' ').trim();

const sectionPatterns = [
  { title: 'Product Features', regex: /^(?:Product\s+Features|Features)\s*:\s*$/i },
  { title: 'Applications', regex: /^Applications\s*:\s*$/i },
  { title: 'Product Benefits', regex: /^(?:Product\s+Benefits|Benefits)\s*:\s*$/i },
  { title: 'Cost Efficiency', regex: /^Cost\s+Efficiency\s*:\s*$/i },
  {
    title: 'Benefits of GK Enterprise MBT Couplers Cost',
    regex: /^Benefits\s+of\s+GK\s+Enterprise\s+MBT\s+Couplers\s+Cost\s*:\s*$/i,
  },
  { title: 'Available Sizes', regex: /^Available\s+Sizes\s*:\s*$/i },
  { title: 'Available Pitch Sizes', regex: /^Available\s+Pitch\s+Sizes\s*:\s*$/i },
];

const formatSectionContent = (value: string) =>
  value
    .replace(/^[-•]\s+/gm, '• ')
    .replace(/\n{3,}/g, '\n\n')
    .trim();

const parseSections = (value: string) => {
  const normalized = normalizeText(value);
  const lines = normalized.split('\n');
  const sections: Array<{ title: string; content: string }> = [];
  const introLines: string[] = [];
  let currentSection: { title: string; content: string[] } | null = null;

  for (const line of lines) {
    const heading = sectionPatterns.find((pattern) => pattern.regex.test(line.trim()));

    if (heading) {
      if (currentSection) {
        sections.push({
          title: currentSection.title,
          content: formatSectionContent(currentSection.content.join('\n')),
        });
      }

      currentSection = { title: heading.title, content: [] };
      continue;
    }

    if (currentSection) {
      currentSection.content.push(line);
    } else {
      introLines.push(line);
    }
  }

  if (currentSection) {
    sections.push({
      title: currentSection.title,
      content: formatSectionContent(currentSection.content.join('\n')),
    });
  }

  const intro = formatSectionContent(introLines.join('\n'));

  if (intro) {
    sections.unshift({ title: 'Description', content: intro });
  }

  return sections.filter((section) => section.content);
};

const sectionBlocks = parseSections(rawDescription);
---

<Layout title={pageTitle}>
  <main class="min-h-screen px-4 pb-12 pt-24 dark:bg-neutral-800 dark:text-white">
    <div class="mx-auto max-w-7xl">
      {product ? (
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
          <div>
            {imageUrl && (
              <img
                src={imageUrl}
                alt={product.name || 'Product image'}
                class="w-full rounded-3xl object-contain"
              />
            )}
          </div>

          <div class="space-y-8">
            <div class="space-y-3">
              <p class="text-sm font-semibold uppercase tracking-[0.25em] text-orange-600">
                {product.category || 'Product'}
              </p>
              <h1 class="text-4xl font-black sm:text-5xl">{product.name}</h1>
            </div>

            {sectionBlocks.length > 0 ? (
              <div class="space-y-6">
                {sectionBlocks.map((section) => (
                  <div class="rounded-3xl border border-neutral-300/80 bg-white/80 p-8 shadow-sm dark:border-neutral-700 dark:bg-neutral-900/70">
                    <h2 class="mb-4 text-2xl font-bold">{section.title}</h2>
                    <p class="whitespace-pre-line text-base leading-8 text-neutral-700 dark:text-neutral-300">
                      {section.content}
                    </p>
                  </div>
                ))}
              </div>
            ) : (
              <div class="rounded-3xl border border-dashed border-neutral-300 p-10 text-center text-lg text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
                No details available.
              </div>
            )}

            <a
              href="/products"
              class="inline-flex items-center gap-2 rounded-full border border-neutral-300 px-5 py-3 text-sm font-semibold text-neutral-800 transition hover:-translate-y-0.5 hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-100 dark:hover:bg-neutral-800"
            >
              ← Back to products
            </a>
          </div>
        </div>
      ) : (
        <div class="rounded-3xl border border-dashed border-neutral-300 p-10 text-center text-lg text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
          Product not found.
        </div>
      )}
    </div>
  </main>
</Layout>