---
// NOTE:
// Replace this parser section with the one from the previous message if needed.
// This file is a template showing where the parsing logic goes.

import Layout from '../../layouts/MainLayout.astro';

export const prerender = false;

const { id } = Astro.params;
const apiBase = import.meta.env.PUBLIC_API || 'https://gk-api-t0fo.onrender.com';

let product: Record<string, any> | null = null;

try {
  const response = await fetch(`${apiBase}/templates/${id}`, {
    cache: 'no-store',
  });

  if (!response.ok) {
    throw new Error(`API Error: ${response.status}`);
  }

  product = await response.json();
} catch (error) {
  console.error(error);
}

const pageTitle = product?.name
  ? `${product.name} | G K Enterprise`
  : 'Product not found | G K Enterprise';

const description = product?.description || 'No description available.';
const highlights = Array.isArray(product?.highlights)
  ? product.highlights
  : [];
---

<Layout title={pageTitle}>
<main class="min-h-screen px-4 pt-24 pb-12 dark:bg-neutral-800 dark:text-white">

<div class="mx-auto max-w-7xl">

{product ? (

<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

<div>
<img src={product.image_url} alt={product.name} class="rounded-3xl w-full"/>
</div>

<div class="space-y-8">

<h1 class="text-5xl font-black">{product.name}</h1>

{
!/^\s*Product\s*Features\s*:?\s*$/i.test(rawDescription) && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">Description</h3>
<p set:html={descriptionOnly}></p>
</div>
)
}

{
description.includes("###PRODUCT_FEATURES###") && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">Product Features</h3>
<p set:html={description.split("###PRODUCT_FEATURES###")[1]?.split("###APPLICATIONS###")[0]?.split("###PRODUCT_BENEFITS###")[0]?.split("###COST_EFFICIENCY###")[0]?.split("###BENEFITS_COST###")[0]} />
</div>
)
}

{
description.includes("###APPLICATIONS###") && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">Applications</h3>
<p
set:html={
description
.split("###AVAILABLE_SIZES###")[1]
?.split("###BENEFITS###")[0]
?.split("###PRODUCT_FEATURES###")[0]
?.split("###APPLICATIONS###")[0]
?.split("###PRODUCT_BENEFITS###")[0]
?.split("###COST_EFFICIENCY###")[0]
}
/>

</div>
)
}

{
description.includes("###PRODUCT_BENEFITS###") && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">Product Benefits</h3>
<p set:html={description.split("###PRODUCT_BENEFITS###")[1]?.split("###COST_EFFICIENCY###")[0]?.split("###BENEFITS_COST###")[0]} />
</div>
)
}

{
description.includes("###COST_EFFICIENCY###") && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">Cost Efficiency</h3>
<p set:html={description.split("###COST_EFFICIENCY###")[1]?.split("###BENEFITS_COST###")[0]} />
</div>
)
}

{
description.includes("###BENEFITS_COST###") && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">Benefits of GK Enterprise MBT Couplers Cost</h3>
<p set:html={description.split("###BENEFITS_COST###")[1]} />
</div>
)
}


{
description.includes("###AVAILABLE_PITCH_SIZES###") && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">
Available Pitch Sizes
</h3>

<p
set:html={
description
.split("###AVAILABLE_PITCH_SIZES###")[1]
?.split("###BENEFITS###")[0]
}


{
description.includes("###BENEFITS###") && (
<div class="rounded-3xl border border-black p-8">
<h3 class="text-xl font-bold mb-5">
Benefits
</h3>

<p
set:html={
description
.split("###BENEFITS###")[1]
}
/>

</div>
)
}
/>

</div>
)
}

</div>

</div>

) : (
<h1>Product not found</h1>
)}

</div>

</main>
</Layout>
