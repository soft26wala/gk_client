---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import ClientsSection from '@components/sections/landing/ClientsSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import PricingSection from '@components/sections/pricing/PricingSection.astro';
import CompanyDeteles from '@components/sections/misc/CompanyDeteles.astro';  
import AnnouncementBanner from '@components/ui/banners/AnnouncementBanner.astro';
import heroImage from '@images/gkpic1.avif';
import faqs from '@data/faqs.json';
import features from '@data/features.json';
import pricing from '@data/pricing.json';
import featureImage from '@images/midpic3.avif';
import construction from '@images/construction-image.avif';
import tools from '@images/automated-tools.avif';
import dashboard from '@images/dashboard-image.avif';
import { partnersData } from '@/data_files/constants';
import Why from '@/components/sections/landing/Why.astro';
import im1 from '@images/inpic/inpic1.avif'
import im2 from '@images/inpic/inpic2.avif'
import im3 from '@images/inpic/inpic3.avif'
import im4 from '@images/inpic/inpic4.avif'
import im5 from '@images/inpic/inpic5.avif'
import im6 from '@images/inpic/inpic6.avif'
import type { ImageMetadata } from 'astro';
import Core from '@/components/sections/landing/Core.astro';

const avatarSrcs: ImageMetadata[]  = [
     im2,
     im3,
     im4,
     im5,
     im6,
     im1,
];
---

<MainLayout>
  <!-- <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Explore ScrewFast on GitHub"
    url="https://github.com/mearashadowfax/ScrewFast"
  /> -->

  <HeroSection
    title=`Manufacturer And Supplier Of Rebar Coupler <span
        class="text-yellow-500 dark:text-yellow-400">G k Enterprise</span>`
    subTitle="GK Enterprise is a leading supplier of high-quality Rebar Couplers and value-added solutions for the construction industry. We provide reliable products and services for infrastructure, residential, commercial, and industrial projects.
              The company is committed to delivering quality products with a strong focus on customer satisfaction, precision, and timely service. We have catered to various projects across India and have built a strong reputation in the market through quality standards and dependable support."
    primaryBtn="Start Exploring"
    primaryBtnURL="/products"
    secondaryBtn="Contact Sales Team"
    secondaryBtnURL="/contact"
    withReview={true}
    alt="Stack of ScrewFast product boxes containing assorted hardware tools"
  />
  <Why />


  <!-- <ClientsSection
    title="Trusted by Industry Leaders"
    subTitle="Experience the reliability chosen by industry giants."
    partners={partnersData}
  /> -->

  <FeaturesGeneral
    title="Powering Modern Infrastructure"
    subTitle="GK Enterprise proudly delivers high-quality engineering and construction support products for leading government, infrastructure, and private sector projects. With a strong commitment to reliability, innovation, and timely execution, we cater to diverse industrial and construction requirements across India.
Backed by an experienced team and modern operational capabilities, we ensure superior product quality, efficient service, and dependable project support. Our focus on precision, customer satisfaction, and long-term partnerships enables us to contribute effectively to projects of every scale.
In addition to our core solutions, we provide a wide range of industrial products, structural materials, fabrication support, and construction accessories sourced from trusted brands. We aim to deliver cost-effective and durable solutions tailored to the evolving needs of modern infrastructure and engineering projects."
    
    
  />


 <Core />


  <div
    class="mb-10 text-center"
    data-aos="zoom-out-right"
    data-aos-duration="2000"
  >
    <h2
      class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white md:text-5xl"
    >
      Products We Offer
    </h2>

    <p
      class="mx-auto mt-3 max-w-2xl text-base text-neutral-600 dark:text-neutral-400"
      data-aos="zoom-out-left"
      data-aos-duration="2000"
    >
      Explore our range of products designed to meet your construction needs.
      From cutting-edge tools to robust features, we have everything you need to
      build with confidence.
    </p>
  </div>

  <PricingSection pricing={pricing} />

  <CompanyDeteles />

  <!-- <HeroSectionAlt
    title="Let's Build Together"
    subTitle="ScrewFast is an open-source template, meticulously crafted with Astro, Tailwind CSS, and Preline UI frameworks."
    url="https://github.com/mearashadowfax/ScrewFast"
  /> -->


  <!-- WhatsApp Floating Button -->
<a
  href="https://wa.me/917859845464?text=Hello%20GK%20Enterprise%2C%20I%20want%20more%20information."
  target="_blank"
  rel="noopener noreferrer"
  class="group fixed bottom-6 right-6 z-50 flex items-center gap-3 rounded-full border border-green-400/20 bg-green-500 px-5 py-3 shadow-2xl transition duration-300 hover:scale-105 hover:bg-green-600"
>
  <!-- WhatsApp Icon -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    class="h-7 w-7 dark:fill-white fill-black"
  >
    <path
      d="M16.04 3C8.84 3 3 8.74 3 15.82c0 2.5.74 4.92 2.13 7L3 29l6.39-2.08a13.2 13.2 0 0 0 6.65 1.8H16c7.2 0 13.04-5.74 13.04-12.82C29.04 8.74 23.2 3 16.04 3Zm0 23.4c-2.04 0-4.03-.55-5.77-1.6l-.41-.24-3.79 1.23 1.24-3.68-.27-.43a10.4 10.4 0 0 1-1.6-5.56c0-5.8 4.78-10.52 10.66-10.52 5.89 0 10.67 4.72 10.67 10.52 0 5.8-4.78 10.52-10.67 10.52Zm5.85-7.86c-.32-.16-1.9-.93-2.2-1.04-.3-.1-.52-.16-.74.16-.21.31-.84 1.03-1.02 1.24-.19.21-.37.24-.69.08-.31-.16-1.33-.48-2.53-1.53-.93-.82-1.56-1.83-1.74-2.14-.18-.31-.02-.48.14-.64.14-.14.31-.37.47-.55.15-.18.2-.31.3-.52.1-.21.05-.39-.03-.55-.08-.16-.74-1.78-1.02-2.43-.26-.63-.52-.55-.74-.56h-.63c-.21 0-.55.08-.84.39-.29.31-1.1 1.08-1.1 2.64 0 1.55 1.13 3.05 1.29 3.26.16.21 2.22 3.52 5.49 4.8.78.3 1.39.48 1.86.62.78.24 1.49.2 2.05.12.63-.1 1.9-.78 2.17-1.53.27-.76.27-1.4.19-1.53-.08-.13-.29-.21-.61-.37Z"
    />
  </svg>

  <!-- Text -->
  <div class="hidden sm:block">
    <p class="text-sm font-semibold dark:text-white text-black">
      Chat on WhatsApp
    </p>

    <p class="gre">
      Quick Support
    </p>
  </div>
</a>



</MainLayout>



