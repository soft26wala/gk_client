---
import type { describe } from 'astro:schema';
import AdminLayout from '../layouts/AdminLayout.astro';
// Simulando datos que vendrían de tu base de datos Postgres
let users = [];
try {
  const response = await fetch(`${import.meta.env.PUBLIC_API}/user/all`);
  users = await response.json();
  // console.log("user :", await users)
} catch (e) {
  // Agar backend off hai to ye dikhega
  users = [{ name: "Database Offline", email: "check backend", date: "-" }];
}


let temp = [];
try {
  const response = await fetch(`${import.meta.env.PUBLIC_API}/templates/all`);
  temp = await response.json();
  // console.log("temp :", await temp)
} catch (e) {
  // Agar backend off hai to ye dikhega
  temp = [{ name: "Database Offline", describe: "check backend", date: "-" }];
}
---

<AdminLayout title="Admin Console | G K Enterprise">
  <div class="min-h-screen p-4 md:p-10 bg-[#0a0a0a] text-white font-sans">
    
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-neutral-500">
          G K Enterprise Dashboard
        </h1>
        <p class="text-neutral-500 mt-1">Manage your business infrastructure and growth.</p>
      </div>
      <div class="flex gap-3">
        <div class="bg-white/5 border border-white/10 px-4 py-2 rounded-2xl backdrop-blur-md">
          <span class="text-orange-500 font-bold">Status:</span> <span class="text-green-400">Live</span>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <div class="lg:col-span-8 space-y-8">
        
        <section class="relative group overflow-hidden bg-neutral-900/50 border border-white/10 p-8 rounded-[2rem] shadow-2xl backdrop-blur-3xl">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-orange-500/10 blur-[80px] rounded-full"></div>
          
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add Premium Template
          </h2>

          <form id="uploadForm" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="space-y-2">
                <label class="text-sm text-neutral-400 ml-1">Template Name</label>
                <input type="text" name="name" placeholder="e.g. Real Estate Pro" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3 focus:border-orange-500 outline-none transition-all" required />
              </div>
              <div class="space-y-2">
                <label class="text-sm text-neutral-400 ml-1">Category</label>
                <input type="text" name="category" placeholder="Business / Gym" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3 focus:border-orange-500 outline-none transition-all" />
              </div>
            </div>

            <div class="space-y-2">
                <label class="text-sm text-neutral-400 ml-1">Description</label>
                <textarea name="description" rows="3" placeholder="Describe the product..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3 focus:border-orange-500 outline-none transition-all"></textarea>
            </div>

            <div class="relative group border-2 border-dashed border-white/10 rounded-[1.5rem] p-10 text-center hover:border-orange-500/50 transition-all cursor-pointer bg-white/[0.02]">
              <input type="file" name="image" id="file-input" class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*" />
              <div class="space-y-3">
                <div class="bg-orange-500/20 w-14 h-14 rounded-2xl flex items-center justify-center mx-auto text-orange-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                  </svg>
                </div>
                <p class="text-neutral-300 font-medium">Click to upload image to Cloudinary</p>
                <p class="text-xs text-neutral-500">PNG, JPG up to 10MB</p>
              </div>
            </div>

            <button type="submit" class="w-full bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-black py-4 rounded-2xl transition-all shadow-xl shadow-orange-500/20 uppercase tracking-widest">
              Publish Template
            </button>
          </form>
        </section>

        <section class="bg-neutral-900/50 border border-white/10 rounded-[2rem] overflow-hidden">
          <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h2 class="text-xl font-bold">Your Templates</h2>
            <span class="text-xs text-neutral-500">{temp.length} Total</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead class="bg-white/5 text-neutral-400 text-xs uppercase tracking-tighter">
                <tr>
                  <th class="px-6 py-4">name</th>
                  <th class="px-6 py-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {temp.map((template: any) => (
                  <tr class="hover:bg-white/[0.02] transition-colors">
                    <td class="px-6 py-4">
                      <div class="font-bold text-white">{template.name}</div>
                    </td>
                    <td class="px-6 py-4 text-sm text-neutral-400">{template.date}</td>
                    <td class="px-6 py-4 text-right">
                      <button 
                        class="edit-btn bg-orange-500/10 text-orange-400 text-[10px] font-bold px-3 py-2 rounded-md uppercase hover:bg-orange-500 hover:text-white transition-all cursor-pointer"
                        data-id={template.id}
                        data-name={template.name}
                        data-category={template.category}
                        data-description={template.description}
                        data-image={template.image}
                      >
                        Edit
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>


          <section class="bg-neutral-900/50 border border-white/10 rounded-[2rem] overflow-hidden">
          <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h2 class="text-xl font-bold">Registered Users</h2>
            <span class="text-xs text-neutral-500">{users.length} Total</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead class="bg-white/5 text-neutral-400 text-xs uppercase tracking-tighter">
                <tr>
                  <th class="px-6 py-4">User</th>
                  <th class="px-6 py-4">Joined Date</th>
                  <th class="px-6 py-4 text-right">Access</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {users.map((user: any) => (
                  <tr class="hover:bg-white/[0.02] transition-colors">
                    <td class="px-6 py-4">
                      <div class="font-bold text-white">{user.name}</div>
                      <div class="text-xs text-neutral-500">{user.email}</div>
                    </td>
                    <td class="px-6 py-4 text-sm text-neutral-400">{user.date}</td>
                    <td class="px-6 py-4 text-right">
                      <span class="bg-orange-500/10 text-orange-400 text-[10px] font-bold px-2 py-1 rounded-md uppercase">Member</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div class="lg:col-span-4 space-y-6">
        <h3 class="text-sm font-bold text-neutral-500 uppercase tracking-widest px-2 italic">Premium Locked Modules</h3>
        
        {['Callback Requests', 'Payment Gateway', 'Smart Booking', 'Auto Invoice'].map((item) => (
          <div class="group relative overflow-hidden p-6 rounded-[2rem] border border-white/5 bg-gradient-to-br from-white/[0.05] to-transparent grayscale hover:grayscale-0 transition-all cursor-not-allowed">
            <div class="flex justify-between items-start mb-4">
              <div class="bg-white/10 p-3 rounded-2xl group-hover:bg-orange-500/20 group-hover:text-orange-500 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <span class="text-[10px] font-bold bg-white/10 px-2 py-1 rounded-lg">LOCKED</span>
            </div>
            <h4 class="text-lg font-bold text-neutral-300 group-hover:text-white">{item}</h4>
            <p class="text-xs text-neutral-500 mt-1">Scale your business with {item.toLowerCase()} system.</p>
            
            <div class="mt-4 pt-4 border-t border-white/5">
              <div class="text-[10px] font-black text-orange-500 bg-orange-500/10 px-3 py-2 rounded-xl text-center">
                CHANGE TO UPGRADES WEB TO UNLOCK
              </div>
            </div>
          </div>
        ))}

        <div class="p-6 rounded-[2rem] bg-gradient-to-br from-orange-500 to-orange-700 text-white shadow-2xl shadow-orange-500/20">
          <h4 class="font-black text-xl mb-2">Expansion Budget</h4>
          <p class="text-sm opacity-90 mb-4">Current scaling strategy targets 1Cr to 100Cr growth.</p>
          <div class="text-2xl font-black">₹ 30,00,000</div>
          <p class="text-[10px] uppercase opacity-70 mt-1">Projected Branding Allocation</p>
        </div>
      </div>

    </div>
  </div>


  <div id="editModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm p-4">
  <div class="bg-neutral-900 border border-white/10 w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden relative">
    <button id="closeModal" class="absolute top-6 right-6 text-neutral-500 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="p-8 md:p-10">
      <h2 class="text-2xl font-black mb-6 bg-clip-text text-transparent bg-gradient-to-r from-orange-400 to-orange-600">
        Update Template
      </h2>

      <form id="editForm" class="space-y-5">
        <input type="hidden" name="id" id="edit-id" />
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="space-y-2">
            <label class="text-xs text-neutral-500 uppercase font-bold tracking-widest ml-1">Name</label>
            <input type="text" name="name" id="edit-name" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3 focus:border-orange-500 outline-none transition-all" required />
          </div>
          <div class="space-y-2">
            <label class="text-xs text-neutral-500 uppercase font-bold tracking-widest ml-1">Category</label>
            <input type="text" name="category" id="edit-category" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3 focus:border-orange-500 outline-none transition-all" />
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-xs text-neutral-500 uppercase font-bold tracking-widest ml-1">Description</label>
          <textarea name="description" id="edit-description" rows="3" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3 focus:border-orange-500 outline-none transition-all"></textarea>
        </div>

        <div class="flex items-center gap-4 p-4 bg-white/[0.02] rounded-2xl border border-white/5">
          <img id="edit-preview" src="" class="w-20 h-14 object-cover rounded-xl border border-white/10" />
          <div class="flex-1">
            <label class="text-[10px] text-neutral-500 uppercase font-bold">New Image (Optional)</label>
            <input type="file" name="image" class="w-full text-xs text-neutral-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:bg-white/10 file:text-white" />
          </div>
        </div>

        <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-black py-4 rounded-2xl transition-all shadow-xl shadow-orange-500/20 uppercase tracking-widest mt-4">
          Save Changes
        </button>
      </form>
    </div>
  </div>
</div>


  <script>


const modal = document.getElementById('editModal');
  const editForm = document.querySelector<HTMLFormElement>('#editForm');
  const closeModalBtn = document.getElementById('closeModal');

  // 1. Edit buttons par click listener lagana (data-* attributes se data lena)
  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const editId = document.getElementById('edit-id') as HTMLInputElement | null;
      const editName = document.getElementById('edit-name') as HTMLInputElement | null;
      const editCategory = document.getElementById('edit-category') as HTMLInputElement | null;
      const editDescription = document.getElementById('edit-description') as HTMLTextAreaElement | null;
      const editPreview = document.getElementById('edit-preview') as HTMLImageElement | null;

      const b = btn as HTMLButtonElement;
      if (editId) editId.value = b.dataset.id ?? '';
      if (editName) editName.value = b.dataset.name ?? '';
      if (editCategory) editCategory.value = b.dataset.category ?? '';
      if (editDescription) editDescription.value = b.dataset.description ?? '';
      if (editPreview) editPreview.src = b.dataset.image ?? ''; // Purani image dikhana

      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    });
  });

  // 2. Popup band karna
  closeModalBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  });

  // 3. PUT Request (Update logic)
  editForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const idInput = document.getElementById('edit-id') as HTMLInputElement | null;
    if (!idInput) {
      window.showToast("Missing edit id field.", 'error');
      return;
    }
    const id = idInput.value;
    const formData = new FormData(editForm);

    const btn = editForm.querySelector<HTMLButtonElement>('button');
    if (!btn) return;
    btn.innerText = "Updating...";
    btn.disabled = true;

    try {
      const apiBase = import.meta.env.PUBLIC_API || 'https://gk-api-t0fo.onrender.com';
      const response = await fetch(`${apiBase}/templates/${id}`, {
        method: 'PUT',
        body: formData,
      });

      if (response.ok) {
        window.showToast("Template Updated Successfully!", 'success');
        window.location.reload();
      } else {
        window.showToast("Update Failed!", 'error');
      }
    } catch (err) {
      console.error(err);
      window.showToast("Server Error!", 'error');
    } finally {
      btn.innerText = "Save Changes";
      btn.disabled = false;
    }
  });


  const form = document.querySelector<HTMLFormElement>('#uploadForm');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const currentForm = e.currentTarget as HTMLFormElement;

    // UI par loading dikhane ke liye
    const btn = currentForm.querySelector<HTMLButtonElement>('button');
    if (!btn) return;
    const originalText = btn.innerText;
    btn.innerText = "Uploading to Cloudinary...";
    btn.disabled = true;

    const formData = new FormData(currentForm);

    try {
      const apiBase = import.meta.env.PUBLIC_API || 'https://gk-api-t0fo.onrender.com';
      const response = await fetch(`${apiBase}/templates`, {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        const result = await response.json();
        window.showToast("Success! Template Published.", 'success');
        currentForm.reset();
        window.location.reload();
      } else {
        const errorData = await response.json();
        window.showToast("Error: " + errorData.error, 'error');
      }
    } catch (err) {
      console.error(err);
      window.showToast("Server connection failed!", 'error');
    } finally {
      btn.innerText = originalText;
      btn.disabled = false;
    }
  });
</script>
</AdminLayout>