---
const apiBase = import.meta.env.PUBLIC_API || 'https://gk-api-t0fo.onrender.com';
---

<section class="relative mx-auto max-w-[95rem] px-4 py-14">


  <div class="relative">
    <button
      id="scrollLeft"
      class="absolute left-0 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white shadow-lg backdrop-blur-xl transition hover:scale-110 hover:bg-white/20 dark:bg-black/40 md:flex"
      aria-label="Scroll products left"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>

    <button
      id="scrollRight"
      class="absolute right-0 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white shadow-lg backdrop-blur-xl transition hover:scale-110 hover:bg-white/20 dark:bg-black/40 md:flex"
      aria-label="Scroll products right"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </button>

    <div
      id="templateSlider"
      class="flex gap-6 overflow-x-auto scroll-smooth pb-2 snap-x snap-mandatory [-ms-overflow-style:none] [scrollbar-width:none]"
      data-api-base={apiBase}
      aria-live="polite"
    >
      {
        Array.from({ length: 4 }).map(() => (
          <div class="min-w-[85%] snap-start sm:min-w-[48%] lg:min-w-[31%] xl:min-w-[24%]">
            <div class="overflow-hidden rounded-3xl border border-neutral-200/20 bg-white/70 shadow-xl backdrop-blur-2xl dark:border-white/10 dark:bg-neutral-900/30">
              <div class="h-60 animate-pulse bg-neutral-100 dark:bg-white/10" />
              <div class="space-y-4 p-5">
                <div class="h-6 w-2/3 animate-pulse rounded bg-neutral-200 dark:bg-white/10" />
                <div class="h-4 w-full animate-pulse rounded bg-neutral-200 dark:bg-white/10" />
                <div class="h-10 w-32 animate-pulse rounded-xl bg-neutral-900/20 dark:bg-white/10" />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  #templateSlider::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const slider = document.getElementById('templateSlider');
  const leftBtn = document.getElementById('scrollLeft');
  const rightBtn = document.getElementById('scrollRight');

  const scrollAmount = 350;

  type Template = {
    id: number | string;
    image?: string;
    image_url?: string;
    imageUrl?: string;
    name?: string;
    category?: string;
    description?: string;
  };

  const escapeHtml = (value: unknown) =>
    String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const getTemplateImage = (template: Template) =>
    template.image_url || template.image || template.imageUrl || '';

  const renderTemplateCard = (template: Template) => {
    const id = encodeURIComponent(String(template.id));
    const name = template.name || 'Product';
    const description = template.description
      ? `${template.description.slice(0, 40)}...`
      : '';

    return `
      <a
        href="${location.origin}/products/${id}"
        onclick="window.location.href='${location.origin}/products/${id}';"
        target="_self"
        class="min-w-[85%] sm:min-w-[48%] lg:min-w-[31%] xl:min-w-[24%] snap-start"
      >
        <div class="group overflow-hidden rounded-3xl border border-neutral-200/20 bg-white/70 shadow-xl backdrop-blur-2xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl dark:border-white/10 dark:bg-neutral-900/30">
          <div class="relative overflow-hidden bg-white">
            <img
              src="${escapeHtml(getTemplateImage(template))}"
              alt="${escapeHtml(name)}"
              class="h-60 w-full object-contain p-4 transition duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <span class="absolute left-4 top-4 rounded-full border border-white/20 bg-black/40 px-3 py-1 text-xs font-semibold text-white backdrop-blur-lg">
              ${escapeHtml(template.category)}
            </span>
          </div>

          <div class="p-5">
            <div class="flex items-center justify-between">
              <h3 class="text-xl font-bold text-neutral-800 dark:text-white">
                ${escapeHtml(name)}
              </h3>

              <div class="rounded-full bg-neutral-200 p-2 transition group-hover:translate-x-1 dark:bg-white/10">
                &rarr;
              </div>
            </div>

            <p class="mt-3 line-clamp-2 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
              ${escapeHtml(description)}
            </p>

            <div class="mt-5">
              <span class="inline-flex items-center gap-2 rounded-xl border border-neutral-300/30 bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:scale-105 dark:bg-white dark:text-black">
                View Details
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </span>
            </div>
          </div>
        </div>
      </a>
    `;
  };

  const loadTemplates = async () => {
    if (!slider) return;

    const apiBase =
      slider.dataset.apiBase || 'https://gk-api-t0fo.onrender.com';

    try {
      const response = await fetch(`${apiBase}/templates`, {
        cache: 'no-store',
      });

      if (!response.ok) {
        throw new Error(`Templates request failed: ${response.status}`);
      }

      const templates = (await response.json()) as Template[];

      if (!Array.isArray(templates) || templates.length === 0) {
        slider.innerHTML =
          '<p class="w-full py-10 text-center text-sm text-neutral-500 dark:text-neutral-400">No products available right now.</p>';
        return;
      }

      slider.innerHTML = templates.map(renderTemplateCard).join('');
    } catch (error) {
      console.error('Error loading templates:', error);
      slider.innerHTML =
        '<p class="w-full py-10 text-center text-sm text-neutral-500 dark:text-neutral-400">Products could not be loaded. Please try again later.</p>';
    }
  };

  loadTemplates();

  if (slider && leftBtn) {
    leftBtn.addEventListener('click', () => {
      slider.scrollBy({
        left: -scrollAmount,
        behavior: 'smooth',
      });
    });
  }

  if (slider && rightBtn) {
    rightBtn.addEventListener('click', () => {
      slider.scrollBy({
        left: scrollAmount,
        behavior: 'smooth',
      });
    });
  }
</script>
