---
// Better Template Data Structure
let templates = [];

try {
  const response = await fetch("http://localhost:4000/templates");
  if (response.ok) {
    templates = await response.json();
    console.log("object :" ,await templates)
  }
} catch (error) {
  console.error("Error cargando plantillas:", error);
  // Opcional: podrías poner datos de respaldo aquí si falla la API
}
// console.log("templates:", templates);
---

<section class="relative mx-auto max-w-[95rem] px-4 py-14">

  <!-- Heading -->
  <div class="mb-10 text-center" data-aos="zoom-out-right" data-aos-duration="2000">
    <h2
      class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white md:text-5xl"
    >
      Products We Offer
    </h2>

    <p
      class="mx-auto mt-3 max-w-2xl text-base text-neutral-600 dark:text-neutral-400"
       data-aos="zoom-out-left" data-aos-duration="2000"
    >
      Explore our range of products designed to meet your construction needs. From cutting-edge tools to robust features, we have everything you need to build with confidence.
    </p>
  </div>

  <!-- Slider Wrapper -->
  <div class="relative">

    <!-- LEFT BUTTON -->
    <button
      id="scrollLeft"
      class="absolute left-0 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white shadow-lg backdrop-blur-xl transition hover:scale-110 hover:bg-white/20 dark:bg-black/40 md:flex"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"
        />
      </svg>
    </button>

    <!-- RIGHT BUTTON -->
    <button
      id="scrollRight"
      class="absolute right-0 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white shadow-lg backdrop-blur-xl transition hover:scale-110 hover:bg-white/20 dark:bg-black/40 md:flex"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"
        />
      </svg>
    </button>

    <!-- TEMPLATE SLIDER -->
    <div
      id="templateSlider"
      class="flex gap-6 overflow-x-auto scroll-smooth pb-2 snap-x snap-mandatory [-ms-overflow-style:none] [scrollbar-width:none]"
    >
      {
        templates.map((template : { id: number; image: string; name: string; category: string; description: string }) => (
          <a
            href={`/products/${template.id}`}
            class="min-w-[85%] sm:min-w-[48%] lg:min-w-[31%] xl:min-w-[24%] snap-start"
          >
            <!-- CARD -->
            <div
              class="group overflow-hidden rounded-3xl border border-neutral-200/20 bg-white/70 shadow-xl backdrop-blur-2xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl dark:border-white/10 dark:bg-white/5"
            >
              <!-- IMAGE -->
              <div class="relative overflow-hidden">
                <img
                  src={template.image}
                  alt={template.name}
                  class="h-60 w-full object-cover transition duration-700 group-hover:scale-110"
                />

                <!-- Overlay -->
                <div
                  class="absolute inset-0 bg-linear-to-t from-black/70 via-black/10 to-transparent"
                ></div>

                <!-- Category -->
                <span
                  class="absolute left-4 top-4 rounded-full border border-white/20 bg-black/40 px-3 py-1 text-xs font-semibold text-white backdrop-blur-lg"
                >
                  {/* {template.category} */}
                </span>
              </div>

              <!-- CONTENT -->
              <div class="p-5">

                <div class="flex items-center justify-between">
                  <h3
                    class="text-xl font-bold text-neutral-800 dark:text-white"
                  >
                    {template.name}
                  </h3>

                  <!-- Arrow -->
                  <div
                    class="rounded-full bg-neutral-200 p-2 transition group-hover:translate-x-1 dark:bg-white/10"
                  >
                    →
                  </div>
                </div>

                <p
                  class="mt-3 line-clamp-2 text-sm leading-6 text-neutral-600 dark:text-neutral-400"
                >
                  {template.description.slice(0, 40)}...
                </p>

                <!-- BUTTON -->
                <div class="mt-5">
                  
                  <span
                    class="inline-flex items-center gap-2 rounded-xl border border-neutral-300/30 bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:scale-105 dark:bg-white dark:text-black"
                  >
                    
                    View Details

                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"
                      />
                    </svg>
                  </span>
                </div>

              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- Hide Scrollbar -->
<style>
  #templateSlider::-webkit-scrollbar {
    display: none;
  }
</style>

<!-- Scroll Buttons -->
<script>
  const slider = document.getElementById("templateSlider");
  const leftBtn = document.getElementById("scrollLeft");
  const rightBtn = document.getElementById("scrollRight");

  const scrollAmount = 350;

  if (slider && leftBtn) {
    leftBtn.addEventListener("click", () => {
      slider.scrollBy({
        left: -scrollAmount,
        behavior: "smooth",
      });
    });
  }

  if (slider && rightBtn) {
    rightBtn.addEventListener("click", () => {
      slider.scrollBy({
        left: scrollAmount,
        behavior: "smooth",
      });
    });
  }
</script>
