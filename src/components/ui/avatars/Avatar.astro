---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const { src, alt } = Astro.props;

interface Props {
  src: string | ImageMetadata;
  alt: string;
}
---

{
  typeof src === 'string' ? (
    <img
      src={src}
      alt={alt}
      class="inline-block h-8 w-8 rounded-full ring-2 ring-neutral-50 dark:ring-neutral-800"
      loading="eager"
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      class="inline-block h-8 w-8 rounded-full ring-2 ring-neutral-50 dark:ring-neutral-800"
      loading="eager"
    />
  )
}